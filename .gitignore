*.gguf
*.bin
*.safetensors
*.pt
*.pth
*.onnx
*.crdownload
custom-wazuh-model_gguf/*.gguf

# OS/editor noise
.DS_Store
Thumbs.db
.idea/

# Keep personal VS Code preferences local. Remove this if you want to share them.
.vscode/
