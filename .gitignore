# Python cache/build artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/
*.egg-info/

# Virtual environments and local env files
.venv/
venv/
env/
.env
.env.*

# Runtime logs and generated SIEM output
*.log
reports/*
!reports/.gitkeep
src/reports/
tmp_reports/
tmp_fix_probe/
_codex_probe/
DO_NOT_UPLOAD_LOCAL/

